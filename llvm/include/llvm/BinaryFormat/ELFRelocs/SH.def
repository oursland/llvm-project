#ifndef ELF_RELOC
#error "ELF_RELOC must be defined"
#endif

// Defined in the SuperH ELF ABI.
ELF_RELOC(R_SH_NONE, 0)
ELF_RELOC(R_SH_DIR32, 1)
ELF_RELOC(R_SH_REL32, 2)
ELF_RELOC(R_SH_DIR8WPN, 3)
ELF_RELOC(R_SH_IND12W, 4)
ELF_RELOC(R_SH_DIR8WPL, 5)
ELF_RELOC(R_SH_DIR8WPZ, 6)
ELF_RELOC(R_SH_DIR8BP, 7)
ELF_RELOC(R_SH_DIR8W, 8)
ELF_RELOC(R_SH_DIR8L, 9)
ELF_RELOC(R_SH_LOOP_START, 10)
ELF_RELOC(R_SH_LOOP_END, 11)
ELF_RELOC(R_SH_DIR16, 12)
ELF_RELOC(R_SH_DIR8, 13)
ELF_RELOC(R_SH_DIR4, 14)
ELF_RELOC(R_SH_DIR8CE, 15)
ELF_RELOC(R_SH_REL8, 16)
ELF_RELOC(R_SH_REL12, 17)
ELF_RELOC(R_SH_DISP12, 17) // alias for REL12 in some variants
ELF_RELOC(R_SH_DISP8,  16) // alias for REL8 in some variants

ELF_RELOC(R_SH_TLS_IE_32, 147)
ELF_RELOC(R_SH_TLS_LE_32, 148)
ELF_RELOC(R_SH_TLS_DTPMOD32, 149)
ELF_RELOC(R_SH_TLS_DTPOFF32, 150)
ELF_RELOC(R_SH_TLS_TPOFF32, 151)
ELF_RELOC(R_SH_GOT32, 160)
ELF_RELOC(R_SH_PLT32, 161)
ELF_RELOC(R_SH_COPY, 162)
ELF_RELOC(R_SH_GLOB_DAT, 163)
ELF_RELOC(R_SH_JMP_SLOT, 164)
ELF_RELOC(R_SH_RELATIVE, 165)
ELF_RELOC(R_SH_GOTOFF, 166)
ELF_RELOC(R_SH_GOTPC, 167)

